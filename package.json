{
  "name": "vilagjaro",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/lib/vilagjaro.js",
      "types":  "./dist/lib/vilagjaro-adapter.d.ts"
    }
  },
  "types": "./dist/lib/vilagjaro-adapter.d.ts",
  "files": [
    "dist/lib/",
    "public/"
  ],
  "scripts": {
    "dev":       "vite",
    "build":     "tsc && vite build",
    "build:lib": "rm -rf dist/lib && tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "preview":   "vite preview"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "ol": "^10.8.0",
    "osmtogeojson": "^3.0.0-beta.5"
  }
}
